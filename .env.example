# Copy this file to .env and fill in your real values.
# .env is gitignored and will NEVER be uploaded.

# Get your Gemini API key from https://aistudio.google.com/apikey
# Used for: AI question generator chat, phonetics (pinyin/zhuyin) backfill.
GEMINI_API_KEY=your_api_key_here

# Get your Hugging Face token at https://huggingface.co/settings/tokens
# Needs the "Make calls to Inference Providers" permission.
# Used for: the ✨ Generate AI Image button (FLUX.1-schnell).
HF_TOKEN=your_hf_token_here

# Optional: local dev port (default 3000)
PORT=3000

# Vercel KV credentials — leave blank for local dev (will use data/*.json instead).
# On Vercel, these are auto-injected when you connect a KV database to the project.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
